   INPUTS
       base     - absolute base URL.
       relative - relative or absolute reference.

   RESULT
       url - allocated absolute URL or NULL.

   SEE ALSO
       ParseHttpUrl(), HttpTransactionPerform()

amihttp.library/NewHttpCookieJar                 amihttp.library/NewHttpCookieJar

   NAME
       NewHttpCookieJar -- Allocate cookie storage.  (V1)

   SYNOPSIS
       jar = NewHttpCookieJar();
       D0

       struct HttpCookieJar *NewHttpCookieJar(VOID);

   FUNCTION
       Creates empty cookie jar for HttpSessionAttachCookieJar().

   RESULT
       jar - handle or NULL.

   SEE ALSO
       DisposeHttpCookieJar(), HttpSessionAttachCookieJar()

amihttp.library/DisposeHttpCookieJar         amihttp.library/DisposeHttpCookieJar

   NAME
       DisposeHttpCookieJar -- Free cookie jar.  (V1)

   SYNOPSIS
       DisposeHttpCookieJar(jar);
                            A0

       VOID DisposeHttpCookieJar(struct HttpCookieJar *jar);

   FUNCTION
       Detach from any session before disposing.

   INPUTS
       jar - cookie jar handle.

   SEE ALSO
       NewHttpCookieJar()

amihttp.library/LoadHttpCookieJar               amihttp.library/LoadHttpCookieJar

   NAME
       LoadHttpCookieJar -- Load Netscape cookie file.  (V1)

   SYNOPSIS
       success = LoadHttpCookieJar(jar, filename);
       D0                            A0   A1

       LONG LoadHttpCookieJar(struct HttpCookieJar *, STRPTR filename);

   FUNCTION
       Reads cookies from disk into jar.

   INPUTS
       jar      - cookie jar.
       filename - path to cookie file.

   RESULT
       success - TRUE (1) or FALSE (0).

   SEE ALSO
       SaveHttpCookieJar()

amihttp.library/SaveHttpCookieJar               amihttp.library/SaveHttpCookieJar

   NAME
       SaveHttpCookieJar -- Write Netscape cookie file.  (V1)

   SYNOPSIS
       success = SaveHttpCookieJar(jar, filename);
       D0                            A0   A1

       LONG SaveHttpCookieJar(struct HttpCookieJar *, STRPTR filename);

   FUNCTION
       Persists jar contents to disk.

   INPUTS
       jar      - cookie jar.
       filename - output path.

   RESULT
       success - TRUE (1) or FALSE (0).

   SEE ALSO
       LoadHttpCookieJar()

amihttp.library/FlushHttpCookieJar             amihttp.library/FlushHttpCookieJar

   NAME
       FlushHttpCookieJar -- Trim cookie count.  (V1)

   SYNOPSIS
       FlushHttpCookieJar(jar, max_count);
                          A0   D0

       VOID FlushHttpCookieJar(struct HttpCookieJar *, ULONG max_count);

   FUNCTION
       Removes oldest cookies until at most max_count remain.

   INPUTS
       jar       - cookie jar.
       max_count - maximum cookies to keep.

   SEE ALSO
       NewHttpCookieJar()

amihttp.library/SetHttpCookie                       amihttp.library/SetHttpCookie

   NAME
       SetHttpCookie -- Add cookie from Set-Cookie line.  (V1)

   SYNOPSIS
       success = SetHttpCookie(jar, cookie_line);
       D0                      A0   A1

       LONG SetHttpCookie(struct HttpCookieJar *, STRPTR cookie_line);

   FUNCTION
       Parses Set-Cookie / Cookie header line into jar (document.cookie
       style API).

   INPUTS
       jar         - cookie jar.
       cookie_line - full cookie spec string.

   RESULT
       success - TRUE (1) or FALSE (0).

   SEE ALSO
       GetHttpCookieString()

amihttp.library/GetHttpCookieString           amihttp.library/GetHttpCookieString

   NAME
       GetHttpCookieString -- Cookie header value for URL.  (V1)

   SYNOPSIS
       str = GetHttpCookieString(jar, url);
       D0                        A0   A1

       STRPTR GetHttpCookieString(struct HttpCookieJar *, STRPTR url);

   FUNCTION
       Builds Cookie: header payload for given request URL.  Caller frees
       with Free().

   INPUTS
       jar - cookie jar.
       url - request URL for domain/path matching.

   RESULT
       str - "name=value; name2=value2" or NULL if none.

   SEE ALSO
       SetHttpCookie(), HttpSessionAttachCookieJar()
