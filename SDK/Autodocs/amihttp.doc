amihttp.library/SetHttpSessionHook             amihttp.library/SetHttpSessionHook

   NAME
       SetHttpSessionHook -- Install a session-wide hook.  (V1)

   SYNOPSIS
       success = SetHttpSessionHook(session, type, hook);
       D0                           A0       D0    A1

       LONG SetHttpSessionHook(struct HttpSession *, ULONG, struct Hook *);

   FUNCTION
       Stores a struct Hook pointer for hook type HTHK_*.  Used as fallback
       when no transaction hook is set.  See amihttp.library/hooks.

   INPUTS
       session - HttpSession handle.
       type    - HTHK_PROGRESS .. HTHK_LOG (1..8).
       hook    - Hook structure, or NULL to clear.

   RESULT
       success - TRUE (1) or FALSE (0).

   SEE ALSO
       SetHttpTransactionHook(), amihttp.library/hooks

amihttp.library/HttpSessionAttachCookieJar amihttp.library/HttpSessionAttachCookieJar

   NAME
       HttpSessionAttachCookieJar -- Attach cookie jar to session.  (V1)

   SYNOPSIS
       success = HttpSessionAttachCookieJar(session, jar);
       D0                                   A0       A1

       LONG HttpSessionAttachCookieJar(struct HttpSession *,
           struct HttpCookieJar *);

   FUNCTION
       Associates a cookie jar with the session.  Outbound requests gain
       Cookie: headers; Set-Cookie response headers update the jar.  The
       session does not own the jar — caller must keep jar alive until
       detach or session dispose.

   INPUTS
       session - HttpSession handle.
       jar     - HttpCookieJar from NewHttpCookieJar(), or NULL to clear.

   RESULT
       success - TRUE (1) or FALSE (0).

   SEE ALSO
       HttpSessionDetachCookieJar(), NewHttpCookieJar()

amihttp.library/HttpSessionDetachCookieJar amihttp.library/HttpSessionDetachCookieJar

   NAME
       HttpSessionDetachCookieJar -- Remove cookie jar from session.  (V1)

   SYNOPSIS
       HttpSessionDetachCookieJar(session);
                                  A0

       VOID HttpSessionDetachCookieJar(struct HttpSession *);

   FUNCTION
       Clears the session cookie jar pointer without disposing the jar.

   INPUTS
       session - HttpSession handle.

   SEE ALSO
       HttpSessionAttachCookieJar()

amihttp.library/NewHttpTransaction         amihttp.library/NewHttpTransaction

   NAME
       NewHttpTransaction -- Create a request/response transaction.  (V1)

   SYNOPSIS
       txn = NewHttpTransaction(session);
       D0                         A0

       struct HttpTransaction *NewHttpTransaction(struct HttpSession *);

   FUNCTION
       Allocates a Tier 2 transaction borrowing session defaults.  Configure
       with SetHttpTransactionAttrsA() before HttpTransactionPerform().

   INPUTS
       session - parent HttpSession handle.

   RESULT
       txn - opaque handle, or NULL on failure.

   SEE ALSO
       DisposeHttpTransaction(), SetHttpTransactionAttrsA(),
       HttpTransactionPerform()

amihttp.library/DisposeHttpTransaction     amihttp.library/DisposeHttpTransaction

   NAME
       DisposeHttpTransaction -- Free transaction state.  (V1)

   SYNOPSIS
       DisposeHttpTransaction(txn);
                              A0

       VOID DisposeHttpTransaction(struct HttpTransaction *txn);

   FUNCTION
       Releases transaction resources and returns any pooled connection.
       Waits briefly if an async worker is still running.

   INPUTS
       txn - HttpTransaction handle, or NULL.

   SEE ALSO
       NewHttpTransaction(), AbortHttpTransaction()

amihttp.library/SetHttpTransactionAttrsA amihttp.library/SetHttpTransactionAttrsA

   NAME
       SetHttpTransactionAttrsA -- Configure a transaction.  (V1)

   SYNOPSIS
       success = SetHttpTransactionAttrsA(txn, tags);
       D0                               A0   A1

