amihttp.library/HttpTransactionAddHeader amihttp.library/HttpTransactionAddHeader

   NAME
       HttpTransactionAddHeader -- Add a request header.  (V1)

   SYNOPSIS
       success = HttpTransactionAddHeader(txn, name, value);
       D0                                 A0   A1    A2

       LONG HttpTransactionAddHeader(struct HttpTransaction *, STRPTR, STRPTR);

   FUNCTION
       Appends an HTTP request header (name: value).  Multiple headers with
       the same name are allowed.  Cleared by HttpTransactionClearHeaders().

   INPUTS
       txn   - HttpTransaction handle.
       name  - header field name.
       value - header field value (without leading colon).

   RESULT
       success - TRUE (1) or FALSE (0).

   SEE ALSO
       HttpTransactionClearHeaders(), HttpTransactionPerform()

amihttp.library/HttpTransactionClearHeaders
                                      amihttp.library/HttpTransactionClearHeaders

   NAME
       HttpTransactionClearHeaders -- Remove all request headers.  (V1)

   SYNOPSIS
       HttpTransactionClearHeaders(txn);
                                   A0

       VOID HttpTransactionClearHeaders(struct HttpTransaction *txn);

   FUNCTION
       Removes headers added with HttpTransactionAddHeader().

   INPUTS
       txn - HttpTransaction handle.

   SEE ALSO
       HttpTransactionAddHeader()

amihttp.library/HttpTransactionPerform     amihttp.library/HttpTransactionPerform

   NAME
       HttpTransactionPerform -- Send request and read response headers.  (V1)

   SYNOPSIS
       success = HttpTransactionPerform(txn);
       D0                               A0

       LONG HttpTransactionPerform(struct HttpTransaction *txn);

   FUNCTION
       Resolves URL, acquires pooled TCP/TLS connection, sends request,
       follows redirects when HTSA_FOLLOW_REDIRECTS is enabled, parses
       response headers, and leaves the entity body on the wire for
       HttpTransactionReadBody().  Does not buffer the full body in RAM.

       Honors HTBT_BREAKMASK during blocking I/O.

   INPUTS
       txn - configured HttpTransaction (HTTA_URL required).

   RESULT
       success - TRUE (1) if headers received, FALSE (0) on failure.
           On success, query HttpTransactionGetStatusCode() and response
           headers.  Then loop HttpTransactionReadBody() until 0.

   NOTES
       HTTP 4xx/5xx responses are not library errors unless the connection
       failed.  Check HttpTransactionGetStatusCode().

   SEE ALSO
       HttpTransactionReadBody(), HttpTransactionPerformAsync(),
       HttpTransactionGetStatusCode()

amihttp.library/HttpTransactionPerformAsync
                                      amihttp.library/HttpTransactionPerformAsync

   NAME
       HttpTransactionPerformAsync -- Perform on a worker task.  (V1)

   SYNOPSIS
       success = HttpTransactionPerformAsync(txn);
       D0                                    A0

       LONG HttpTransactionPerformAsync(struct HttpTransaction *txn);

   FUNCTION
       Starts HttpTransactionPerform() on an internal Exec task.  Requires
       HTTA_NOTIFY_TASK and HTTA_NOTIFY_SIGNAL to be set on the transaction.
       Signals the notify task when complete.  Use WaitHttpTransaction() or
       Wait() on the notify signal, then HttpTransactionIsComplete().

   INPUTS
       txn - transaction with notify tags configured.

   RESULT
       success - TRUE (1) if worker started, FALSE (0) if notify tags
           missing or worker could not be created.

   SEE ALSO
       WaitHttpTransaction(), HttpTransactionIsComplete(),
       HTTA_NOTIFY_TASK, HTTA_NOTIFY_SIGNAL

amihttp.library/HttpTransactionIsComplete
                                      amihttp.library/HttpTransactionIsComplete

   NAME
       HttpTransactionIsComplete -- Query async perform completion.  (V1)

   SYNOPSIS
       complete = HttpTransactionIsComplete(txn);
       D0                                 A0

       BOOL HttpTransactionIsComplete(struct HttpTransaction *txn);

   FUNCTION
       Returns TRUE when Perform (sync or async) has finished.  Returns FALSE
       while an async worker is still running.

   INPUTS
       txn - HttpTransaction handle.

   RESULT
       complete - TRUE or FALSE.

   SEE ALSO
       HttpTransactionPerformAsync(), WaitHttpTransaction()

amihttp.library/WaitHttpTransaction           amihttp.library/WaitHttpTransaction

   NAME
       WaitHttpTransaction -- Wait for async perform.  (V1)

   SYNOPSIS
       success = WaitHttpTransaction(txn, timeout_secs);
       D0                            A0   D0

       LONG WaitHttpTransaction(struct HttpTransaction *, ULONG timeout_secs);

   FUNCTION
       Blocks until async perform completes or timeout expires.  Uses
       Wait() on HTTA_NOTIFY_SIGNAL when configured; otherwise polls
       completion with Delay().

   INPUTS
       txn          - HttpTransaction handle.
       timeout_secs - maximum wait in seconds (0 = wait indefinitely on
           notify signal).

   RESULT
       success - TRUE (1) if perform completed successfully, FALSE (0) on
           timeout or perform failure.

   SEE ALSO
       HttpTransactionPerformAsync(), HttpTransactionIsComplete()

amihttp.library/AbortHttpTransaction         amihttp.library/AbortHttpTransaction

   NAME
       AbortHttpTransaction -- Cancel in-progress transaction.  (V1)

   SYNOPSIS
       AbortHttpTransaction(txn);
                            A0

       VOID AbortHttpTransaction(struct HttpTransaction *txn);

   FUNCTION
       Sets abort flag, drops active connection, and causes blocking reads
       to fail with ERROR_HTTP_ABORTED.

   INPUTS
       txn - HttpTransaction handle.

   SEE ALSO
       HttpTransactionPerform(), HttpTransactionReadBody()

amihttp.library/HttpTransactionGetStatusCode
                                      amihttp.library/HttpTransactionGetStatusCode

   NAME
       HttpTransactionGetStatusCode -- HTTP response status code.  (V1)

   SYNOPSIS
       code = HttpTransactionGetStatusCode(txn);
       D0                                  A0

       LONG HttpTransactionGetStatusCode(struct HttpTransaction *txn);

   FUNCTION
       Returns numeric HTTP status from the status line (e.g. 200, 404, 301).
       Independent of HttpError() / GetLastError().

   INPUTS
       txn - HttpTransaction after successful Perform.

   RESULT
       code - HTTP status, or 0 if unavailable.

   SEE ALSO
