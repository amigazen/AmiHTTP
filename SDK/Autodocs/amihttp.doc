   RESULT
       str - read-only description string.

   SEE ALSO
       HttpError(), HttpFault(), amihttp.library/errors

amihttp.library/HttpFault                           amihttp.library/HttpFault

   NAME
       HttpFault -- Format error message into a buffer.  (V1)

   SYNOPSIS
       len = HttpFault(code, header, buffer, buflen);
       D0            D0    A0      A1       D1

       LONG HttpFault(LONG code, STRPTR header, STRPTR buffer, LONG buflen);

   FUNCTION
       Formats a human-readable error line similar to dos.library Fault().
       Useful for printing to stderr or requester text.

   INPUTS
       code   - ERROR_HTTP_* value.
       header - short context string (e.g. function name), may be NULL.
       buffer - caller buffer for formatted text.
       buflen - size of buffer in bytes.

   RESULT
       len - length of formatted string, or 0 on failure.

   SEE ALSO
       HttpError(), HttpGetErrorString()

amihttp.library/NewHttpSession                 amihttp.library/NewHttpSession

   NAME
       NewHttpSession -- Allocate a client session context.  (V1)

   SYNOPSIS
       session = NewHttpSession();
       D0

       struct HttpSession *NewHttpSession(VOID);

   FUNCTION
       Creates a Tier 1 session with sensible defaults (User-Agent
       "amihttp/1.0", follow redirects, keep-alive enabled).  Sessions hold
       settings copied into each HttpTransaction created from them.

   RESULT
       session - opaque handle, or NULL on failure (HttpError()).

   SEE ALSO
       DisposeHttpSession(), SetHttpSessionAttrsA(), NewHttpTransaction()

amihttp.library/DisposeHttpSession         amihttp.library/DisposeHttpSession

   NAME
       DisposeHttpSession -- Free a session.  (V1)

   SYNOPSIS
       DisposeHttpSession(session);
                          A0

       VOID DisposeHttpSession(struct HttpSession *session);

   FUNCTION
       Disposes session state.  All HttpTransaction and HttpConnection handles
       created from this session must be disposed first.

   INPUTS
       session - from NewHttpSession(), or NULL (no action).

   SEE ALSO
       NewHttpSession()

